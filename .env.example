# PostgreSQL
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal_lab
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3001
DATABASE_URL=postgresql://signal:signal@postgres:5432/signal_lab
# Optional. Set locally for Sentry verification; never commit a real DSN.
SENTRY_DSN=

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional. Usually the same DSN for this demo frontend project.
NEXT_PUBLIC_SENTRY_DSN=
# Optional. External Sentry dashboard URL shown in the frontend links panel.
NEXT_PUBLIC_SENTRY_DASHBOARD_URL=

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3100
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Loki
LOKI_PORT=3101
